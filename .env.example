# Google OAuth2 Credentials for Sudarshanaa
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_OAUTH_REDIRECT_URI=http://localhost:5000/oauth/callback

# API base URL for the frontend (leave empty for same-origin proxy)
VITE_API_BASE_URL=

# Seed demo data on backend startup (true/false)
SEED_DEMO_DATA=false

# Database (only needed for postgres profile)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/Sudarshanaa
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=
# JWT Secret for token signing (generate with: openssl rand -hex 32)
Sudarshanaa_JWT_SECRET=your-32-character-random-string-here

# AES-256 Encryption Key for sensitive fields (generate with: openssl rand -hex 32)
Sudarshanaa_ENCRYPTION_KEY=your-64-character-hex-string-for-encryption-here